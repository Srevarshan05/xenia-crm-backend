# ─────────────────────────────────────────────────────────────────────────────
# Xenia CRM – Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/xenia_db

# ─── AI Layer ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Xenia CRM
APP_ENV=development
DEBUG=true
SECRET_KEY=generate-a-secure-random-key-here

# ─── Channel Service ──────────────────────────────────────────────────────────
CHANNEL_SERVICE_URL=http://localhost:8001
CRM_WEBHOOK_URL=http://localhost:8000/api/webhook/delivery

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Brand ────────────────────────────────────────────────────────────────────
BRAND_NAME=Xenia
